---
interface Props {
  title: string;
  description: string;
  tags: string[];
  href?: string;
  repo?: string;
}

const { title, description, tags, href, repo } = Astro.props;
---

<div class="ascii-panel p-5 flex flex-col gap-4 hover:border-zinc-400 transition-colors" data-title="project-record">
  <div class="flex items-start justify-between gap-4">
    <h3 class="font-bold text-zinc-100 uppercase">:: {title}</h3>
    <div class="flex gap-3 shrink-0 text-zinc-400">
      {repo && (
        <a href={repo} target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors text-sm">
          [GitHub]
        </a>
      )}
      {href && (
        <a href={href} target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors text-sm">
          [Live]
        </a>
      )}
    </div>
  </div>
  <p class="text-sm text-zinc-300 leading-relaxed">{description}</p>
  <div class="flex flex-wrap gap-2 mt-1">
    {tags.map(tag => (
      <span class="text-xs text-zinc-400">#{tag}</span>
    ))}
  </div>
</div>
