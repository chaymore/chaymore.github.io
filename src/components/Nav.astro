---
import { pageLinks, site } from '../data/site';
---

<nav class="fixed top-0 left-0 right-0 z-50 border-b border-zinc-700 bg-black/95">
  <div class="site-shell h-16 flex items-center justify-between gap-6">
    <a href="/" class="text-xs sm:text-sm font-bold uppercase tracking-[0.22em] text-zinc-100">~/caleb</a>
    <div class="hidden md:flex gap-1 text-xs text-zinc-400" aria-label="Primary navigation">
      <span class="text-zinc-600">[</span>
      {pageLinks.slice(1).map((link) => (
        <a href={link.href} class="px-2 uppercase hover:text-white transition-colors">{link.label}</a>
      ))}
      <span class="text-zinc-600">]</span>
    </div>
    <div class="md:hidden text-xs text-zinc-400">[MENU]</div>
    <div class="hidden lg:block text-xs text-zinc-600" aria-hidden="true">{site.tagline}</div>
  </div>
  <div class="site-shell nav-mobile md:hidden pb-3">
    {pageLinks.slice(1).map((link) => (
      <a href={link.href} class="uppercase hover:text-white transition-colors">{link.label}</a>
    ))}
  </div>
</nav>
